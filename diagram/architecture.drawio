<mxfile host="app.diagrams.net">
  <diagram name="Architecture" id="namegen-arch">
    <mxGraphModel dx="1400" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Developer -->
        <mxCell id="dev" value="Developer" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="40" y="80" width="140" height="60" as="geometry" />
        </mxCell>

        <!-- GitHub Repo -->
        <mxCell id="ghrepo" value="GitHub Repo&#10;(namegen source + Dockerfile + k8s/ + eksctl/)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="240" y="70" width="200" height="80" as="geometry" />
        </mxCell>

        <!-- GitHub Actions -->
        <mxCell id="ghactions" value="GitHub Actions&#10;(.github/workflows/deploy.yml)&#10;1. Build Docker image&#10;2. Push to ECR&#10;3. kubectl apply / rollout" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="500" y="50" width="240" height="110" as="geometry" />
        </mxCell>

        <!-- ECR -->
        <mxCell id="ecr" value="Amazon ECR&#10;namegen-app repository" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="800" y="60" width="180" height="70" as="geometry" />
        </mxCell>

        <!-- AWS Cloud boundary -->
        <mxCell id="awsCloud" value="AWS (us-east-1)" style="rounded=1;whiteSpace=wrap;html=1;verticalAlign=top;fillColor=none;strokeColor=#232F3E;dashed=1;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="500" y="220" width="900" height="620" as="geometry" />
        </mxCell>

        <!-- EKS Cluster boundary -->
        <mxCell id="eksBox" value="EKS Cluster - Auto Mode (namegen-cluster)" style="rounded=1;whiteSpace=wrap;html=1;verticalAlign=top;fillColor=#f5f5f5;strokeColor=#666666;fontSize=13;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="540" y="270" width="820" height="520" as="geometry" />
        </mxCell>

        <!-- NLB -->
        <mxCell id="nlb" value="AWS Network Load Balancer&#10;(Service type=LoadBalancer, NLB annotations)&#10;created by AWS Load Balancer Controller" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="700" y="320" width="300" height="80" as="geometry" />
        </mxCell>

        <!-- namegen namespace boundary -->
        <mxCell id="nsBox" value="namespace: namegen" style="rounded=1;whiteSpace=wrap;html=1;verticalAlign=top;fillColor=#ffffff;strokeColor=#999999;dashed=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="580" y="440" width="740" height="320" as="geometry" />
        </mxCell>

        <!-- App Deployment -->
        <mxCell id="appDeploy" value="Deployment: namegen-app&#10;(2 replicas, port 8080)&#10;env: MONGODB_URL (Secret)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="620" y="490" width="280" height="90" as="geometry" />
        </mxCell>

        <!-- Pod x2 -->
        <mxCell id="pod1" value="Pod: namegen-app-1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="620" y="600" width="130" height="50" as="geometry" />
        </mxCell>
        <mxCell id="pod2" value="Pod: namegen-app-2" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="770" y="600" width="130" height="50" as="geometry" />
        </mxCell>

        <!-- Headless svc -->
        <mxCell id="mongoSvc" value="Service: mongodb (headless)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="980" y="490" width="260" height="50" as="geometry" />
        </mxCell>

        <!-- StatefulSet -->
        <mxCell id="mongoSts" value="StatefulSet: mongodb&#10;(image: mongo:3.6, --auth)&#10;genuser/password on db 'namegen'" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="980" y="570" width="260" height="80" as="geometry" />
        </mxCell>

        <!-- PVC / PV -->
        <mxCell id="pvc" value="PVC / PersistentVolume&#10;(EBS gp2, 5Gi, via EBS CSI driver)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="980" y="670" width="260" height="70" as="geometry" />
        </mxCell>

        <!-- End user -->
        <mxCell id="user" value="End User (browser)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="240" y="330" width="160" height="60" as="geometry" />
        </mxCell>

        <!-- Arrows -->
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="dev" target="ghrepo">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e1label" value="git push" style="text;html=1;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="195" y="55" width="60" height="20" as="geometry" />
        </mxCell>

        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="ghrepo" target="ghactions">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e2label" value="triggers on push to main" style="text;html=1;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="440" y="30" width="140" height="20" as="geometry" />
        </mxCell>

        <mxCell id="e3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="ghactions" target="ecr">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e3label" value="docker push" style="text;html=1;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="750" y="30" width="80" height="20" as="geometry" />
        </mxCell>

        <mxCell id="e4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="ghactions" target="appDeploy">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e4label" value="kubectl apply / set image (via kubeconfig)" style="text;html=1;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="330" y="200" width="220" height="30" as="geometry" />
        </mxCell>

        <mxCell id="e5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="ecr" target="appDeploy">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e5label" value="pulls image" style="text;html=1;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="880" y="180" width="80" height="20" as="geometry" />
        </mxCell>

        <mxCell id="e6" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="user" target="nlb">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e6label" value="HTTP :80" style="text;html=1;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="440" y="330" width="60" height="20" as="geometry" />
        </mxCell>

        <mxCell id="e7" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="nlb" target="appDeploy">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e8" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="appDeploy" target="pod1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e9" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="appDeploy" target="pod2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e10" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="pod1" target="mongoSvc">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e11" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="pod2" target="mongoSvc">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e10label" value="MONGODB_URL" style="text;html=1;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="900" y="530" width="90" height="20" as="geometry" />
        </mxCell>

        <mxCell id="e12" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="mongoSvc" target="mongoSts">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e13" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="mongoSts" target="pvc">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
